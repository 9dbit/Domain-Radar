# Domain Radar launch environment
# Copy this into Replit Secrets or a local .env file.

# App
NODE_ENV=production
PORT=3000
SESSION_SECRET=replace-with-long-random-secret
ADMIN_EMAIL=admin@domain-radar.local
ADMIN_PASSWORD=replace-with-strong-password
DEMO_PASSWORD=demo123456
DOMAIN_RADAR_DASHBOARD_URL=https://your-domain.example

# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Auth allowlist, optional
# AUTH_EMAIL_ALLOWLIST=merchant1@example.com,merchant2@example.com

# Email / SMTP, required for production verify email and password reset
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Domain Radar <noreply@your-domain.example>"

# Telegram default tenant settings, optional fallback
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Scheduler and checker
CHECK_INTERVAL_SECONDS=300
STATUS_KEYWORDS=blocked,trustpositif,internet positif,nawala
REQUEST_TIMEOUT_MS=15000

# Rank checker
SERPER_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
RANK_MAX_PAGES=10
RANK_SERPER_GL=id
RANK_SERPER_HL=id
RANK_ALLOWED_EXTERNAL_DOMAINS=medium.com,youtube.com,facebook.com,instagram.com,tiktok.com,reddit.com,x.com,twitter.com
RANK_SUSPICIOUS_ALERT_MAX_POSITION=30

# Custom payment gateway placeholder
# Leave PAYMENT_GATEWAY_BASE_URL empty for marketing/demo manual invoices.
PAYMENT_GATEWAY_NAME=custom
PAYMENT_GATEWAY_BASE_URL=
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_SECRET=
PAYMENT_GATEWAY_CALLBACK_SECRET=
PAYMENT_GATEWAY_RETURN_URL=https://your-domain.example
